#!/usr/bin/env bash
# Install a Git pre-commit hook that formats and lints staged markdown.
set -euo pipefail

echo "Setting up Git hooks..."

mkdir -p .git/hooks

cat > .git/hooks/pre-commit << 'PRECOMMIT'
#!/usr/bin/env bash
# Pre-commit hook for markdown formatting and linting.
set -euo pipefail

echo "Running pre-commit checks..."

STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

if [ -z "$STAGED_MD_FILES" ]; then
  echo "No markdown files staged, skipping checks"
  exit 0
fi

file_count=$(echo "$STAGED_MD_FILES" | wc -l)
echo "Checking $file_count markdown file(s)..."

echo "Formatting..."
while IFS= read -r file; do
  [ -z "$file" ] && continue
  if ! prettier --write "$file"; then
    echo "Failed to format $file"
    exit 1
  fi
  git add "$file"
done <<< "$STAGED_MD_FILES"

echo "Linting..."
while IFS= read -r file; do
  [ -z "$file" ] && continue
  if ! markdownlint "$file"; then
    echo "Linting failed for $file"
    echo ""
    echo "Fix the errors above or use 'git commit --no-verify' to skip this check"
    exit 1
  fi
done <<< "$STAGED_MD_FILES"

echo "Pre-commit checks passed"
PRECOMMIT

chmod +x .git/hooks/pre-commit

echo "Git hooks installed successfully"
echo ""
echo "Pre-commit hook will:"
echo "  - Format staged markdown files with prettier"
echo "  - Lint staged markdown files with markdownlint"
echo "  - Prevent commits if linting fails"
echo ""
echo "To bypass the hook (not recommended), use: git commit --no-verify"
